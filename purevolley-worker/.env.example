# PureVolley Worker - Variables d'environnement
# Copier ce fichier en .env et remplir avec vos valeurs

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Wasabi S3 Configuration
WASABI_ACCESS_KEY=your-wasabi-access-key
WASABI_SECRET_KEY=your-wasabi-secret-key
WASABI_BUCKET=purevolley
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.wasabisys.com

# GPU Configuration (pour AMD RX 6600)
HSA_OVERRIDE_GFX_VERSION=10.3.0

# Worker Configuration
POLL_INTERVAL_SECONDS=30
MAX_RETRIES=3
LOG_LEVEL=INFO

# Database Table Names (optionnel - valeurs par défaut)
MATCHES_TABLE=matches
LOGS_TABLE=processing_logs